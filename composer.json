{
    "name": "sendkit/sendkit-laravel",
    "description": "SendKit integration for Laravel",
    "keywords": ["sendkit", "email", "laravel", "mail"],
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0",
        "sendkit/sendkit-php": "^0.1",
        "symfony/mailer": "^7.0"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0",
        "pestphp/pest": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "SendKit\\Laravel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SendKit\\Laravel\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "SendKit\\Laravel\\SendKitServiceProvider"
            ],
            "aliases": {
                "SendKit": "SendKit\\Laravel\\Facades\\SendKit"
            }
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable"
}
